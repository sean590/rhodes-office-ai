{
  "framework": "nextjs",
  "crons": [
    { "path": "/api/cron/compliance-reminders", "schedule": "0 9 * * *" },
    { "path": "/api/cron/inference", "schedule": "0 6 * * *" },
    { "path": "/api/cron/orphan-sweep", "schedule": "0 */2 * * *" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
