{
  "framework": "nextjs",
  "crons": [
    { "path": "/api/cron/compliance-reminders", "schedule": "0 9 * * *" },
    { "path": "/api/cron/backup", "schedule": "0 3 * * *" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
